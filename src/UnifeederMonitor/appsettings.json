{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Monitor": {
    // The ASP.NET WebForms schedule page to monitor.
    "TargetUrl": "https://schedule.unifeeder.com/Softship.Schedule/default.aspx?hsCtaAttrib=164432045133#masterScheduleTab",

    // The vessel name (or other search term) to look up on the page.
    "SearchQuery": "",

    // How often, in minutes, the monitor re-checks the page. Default: 30.
    "PollingIntervalMinutes": 5,

    // Per-operation Playwright timeout, in seconds. Kept low (15s) during debugging so failures surface fast.
    "TimeoutSeconds": 15,

    // Number of retries on a failed scrape cycle before the tick gives up.
    "MaxRetries": 3,

    // Base delay (seconds) between retries. Actual delay = RetryDelaySeconds * attemptNumber.
    "RetryDelaySeconds": 15,

    // Run Chromium headless. Set to false (alongside HeadedDebug) to watch the automation.
    "BrowserHeadless": true,

    // One-time selector discovery: shows the browser and writes debug_dom.html next to the executable.
    "HeadedDebug": false,

    // Optional: path to a custom Chromium executable. Leave empty to use Playwright's managed browser.
    "BrowserExecutablePath": "",

    "Selectors": {
      // Text used to find the "Vessel" search tab (exact match — the tab is labeled "Vessel").
      "VesselSearchTabText": "Vessel",
      // Label of the vessel field (fallback for a role/label lookup).
      "SearchInputLabel": "vessel",
      // Resilient selector for the vessel <input type="text"> autocomplete field: attribute-ends-with
      // match on the stable ID suffix.
      "VesselInputSelector": "input[id$='_searchByVesselAutoCompleter__textBox']",
      // Selector for the autocomplete suggestion list items. The scraper types the query, waits for a
      // suggestion whose text matches, then clicks it (no blind keyboard keys). ASP.NET AutoCompleteExtender
      // commonly renders <li> or .ajax__autocomplete_item; override here if the page uses a different class.
      "AutocompleteSuggestionSelector": "li, .ajax__autocomplete_item",
      // Selector for the "Show terminal information" checkbox, scoped under the active #searchByVesselTab
      // so it matches exactly one element and never the duplicate on the hidden Port tab. The <input> is
      // visually hidden by the site (custom styling), so the scraper uses Force=true to check it.
      "TerminalInfoCheckboxSelector": "#searchByVesselTab .showTerminalInfoCheckBox input[type='checkbox']",
      // Selector for the "Show Schedules" submit button (static ID).
      "SearchButton": "#searchByVesselButton",
      // Broad selector to confirm a results table exists.
      "ResultsTableHint": "table",
      // Results element the scraper awaits + scopes extraction to. Scoped to the PANEL (not … table):
      // the ASP.NET layout nests several layout tables inside the panel, and "… table" matches the first
      // (layout, td-less) table, not the data grid. With the panel as scope, ResultsRowSelector
      // (table tr:has(td)) finds data rows in whichever inner table actually holds them.
      "ResultsContainerSelector": "#searchByVesselResultsPanel",
      // Selector for each data row, scoped under the results container. "table tr:has(td)" searches all
      // tables inside the panel (needed for the nested layout tables) and matches only rows with <td>
      // cells (data rows), skipping <th>-only header rows so headers never hit the hash.
      "ResultsRowSelector": "table tr:has(td)",
      // Only these columns contribute to the change hash. Adjust to the page's real columns.
      "CellSelectors": [
        "td:nth-child(1)",
        "td:nth-child(2)",
        "td:nth-child(4)",
        "td:nth-child(5)",
        "td:nth-child(6)"
      ],
      // Text the panel shows on a genuine empty search. Lets the scraper return gracefully (no retry)
      // instead of throwing when there are simply no matching voyages. Case-insensitive substring.
      "NoResultsText": "No results"
    },

    // Absolute path to the state file. Empty => %LocalAppData%/UnifeederMonitor/state.json
    "StateFilePath": "",

    // Discord webhook URL. Empty => webhook alerts disabled (console logging still runs).
    "DiscordWebhookUrl": "",

    // Email alert settings. EnableEmailAlerts=false skips email entirely (console/Discord still run).
    // IMPORTANT: SenderAppPassword must be a Google App Password, NOT your regular Gmail password.
    // Create one at https://myaccount.google.com/apppasswords (requires 2-Step Verification).
    "Email": {
      "SmtpServer": "smtp.gmail.com",
      "Port": 587,
      "SenderEmail": "",
      "SenderAppPassword": "",
      "RecipientEmail": "",
      "EnableEmailAlerts": false
    }
  }
}
