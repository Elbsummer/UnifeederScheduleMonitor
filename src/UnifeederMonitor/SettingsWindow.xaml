<Window x:Class="UnifeederMonitor.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unifeeder Monitor — Settings"
        Height="320" Width="420"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="True"
        Background="#F5F6F8">
    <Grid Margin="16,14,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                    Text="Edit the monitor configuration below. Saved values are written to appsettings.json."
                    TextWrapping="Wrap"
                    Margin="0,0,0,12"
                    Foreground="#555555"
                    FontSize="11" />

        <!-- Vessel name: strict, data-driven dropdown. Manual text entry is disabled (IsEditable=False)
             so only vessels actually present on the target page can be selected. -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Vessel Name:" VerticalAlignment="Center" Margin="0,0,10,8" />
        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" x:Name="VesselCombo"
                      IsEditable="False"
                      VerticalAlignment="Center"
                      Padding="4,3"
                      SelectionChanged="VesselCombo_SelectionChanged" />
            <Button Grid.Column="1" x:Name="LoadVesselsButton"
                    Content="🔄 Load Vessels"
                    Margin="8,0,0,0" Padding="8,3"
                    Click="LoadVessels_Click" />
        </Grid>

        <!-- Network-activity indicator for the vessel fetch. Collapsed unless a fetch is in progress. -->
        <StackPanel Grid.Row="2" Grid.Column="1" x:Name="LoadingPanel"
                    Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,8">
            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Width="120" Height="12" />
            <TextBlock Text="Loading vessels…" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#666666" />
        </StackPanel>

        <!-- Sender email -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Sender Email:" VerticalAlignment="Center" Margin="0,0,10,8" />
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="SenderEmailBox" VerticalAlignment="Center" Margin="0,0,0,8" Padding="4,3" />

        <!-- Sender password (Google App Password) -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="App Password:" VerticalAlignment="Center" Margin="0,0,10,8" />
        <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="SenderPasswordBox" VerticalAlignment="Center" Margin="0,0,0,8" Padding="4,3" />

        <!-- Recipient email -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Recipient Email:" VerticalAlignment="Center" Margin="0,0,10,8" />
        <TextBox Grid.Row="5" Grid.Column="1" x:Name="RecipientEmailBox" VerticalAlignment="Center" Margin="0,0,0,8" Padding="4,3" />

        <TextBlock Grid.Row="6" Grid.ColumnSpan="2"
                    x:Name="StatusText"
                    TextWrapping="Wrap"
                    Margin="0,8,0,8"
                    Foreground="#666666"
                    FontSize="11"
                    Text="Note: App Password = a Google App Password (https://myaccount.google.com/apppasswords), not your Gmail password. Changing the vessel name clears the stored baseline." />

        <!-- Save / Cancel -->
        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button x:Name="SaveButton" Content="Save" Width="90" Padding="0,5" Margin="0,0,8,0" IsDefault="True" Click="Save_Click" />
            <Button x:Name="CancelButton" Content="Cancel" Width="90" Padding="0,5" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
