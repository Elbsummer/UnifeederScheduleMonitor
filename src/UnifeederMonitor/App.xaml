<Application x:Class="UnifeederMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
             ShutdownMode="OnExplicitShutdown">
    <!-- No StartupUri: this is a tray-only app with no main window.
         ShutdownMode=OnExplicitShutdown keeps the process alive until we call Application.Shutdown()
         from the Exit menu item (otherwise the app would exit as soon as the tray icon is created). -->
    <Application.Resources>
        <tb:TaskbarIcon x:Key="TrayIcon"
                        ToolTipText="Unifeeder Schedule Monitor"
                        IconSource="/Assets/tray.ico"
                        Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="⚙️ Settings..." x:Name="SettingsItem" Click="Settings_Click" />
                    <Separator />
                    <MenuItem Header="Start Monitor" x:Name="StartItem" Click="Start_Click" />
                    <MenuItem Header="Stop Monitor"  x:Name="StopItem"  Click="Stop_Click" IsEnabled="False" />
                    <Separator />
                    <MenuItem Header="Exit"          x:Name="ExitItem"  Click="Exit_Click" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
